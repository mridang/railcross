{
  "name": "railcross",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.worker.json",
    "deploy": "npm run build && wrangler deploy",
    "dev": "wrangler dev",
    "start": "npx nest start",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --verbose --config=jest.config.js --runInBand",
    "test:watch": "npm run test -- --watch",
    "test:debug": "NODE_OPTIONS=--experimental-vm-modules jest --verbose --config=jest.config.js --runInBand --detectOpenHandles",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome"
  },
  "dependencies": {
    "@lifeomic/axios-fetch": "^3.1.0",
    "@mridang/nestjs-defaults": "^2.4.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/serve-static": "^5.0.5",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/types": "^14.1.0",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "axios": "^1.17.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "murmurhash": "^2.0.1",
    "nestjs-cls": "^5.4.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "engines": {
    "node": "22.x"
  },
  "repository": {
    "url": "https://github.com/mridang/railcross"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@jest/globals": "^30.4.1",
    "@mridang/eslint-defaults": "^1.6.3",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.26",
    "@tsconfig/node22": "^22.0.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.21",
    "@types/supertest": "^6.0.3",
    "cypress": "^14.5.4",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "knip": "^5.88.1",
    "nock": "^14.0.15",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.99.0"
  }
}
