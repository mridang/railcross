{
  "name": "railcross",
  "version": "0.0.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "opennextjs-cloudflare build",
    "start": "next start",
    "deploy:worker": "npx wrangler@3 deploy --config wrangler.worker.toml",
    "deploy:app": "npm run build:worker && wrangler deploy",
    "deploy": "npm run deploy:worker && npm run deploy:app",
    "test": "jest --verbose --config=jest.config.js --runInBand",
    "test:watch": "npm run test -- --watch",
    "test:debug": "jest --verbose --config=jest.config.js --runInBand --detectOpenHandles",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --browser chrome",
    "wrangler": "wrangler"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.1.2",
    "@octokit/rest": "^20.0.2",
    "@octokit/webhooks": "^12.0.0",
    "@octokit/webhooks-types": "^7.4.0",
    "@sentry/nextjs": "^8.0.0",
    "badge-maker": "^5.0.2",
    "jose": "^5.2.0",
    "murmurhash": "^2.0.1",
    "next": "^15.5.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rxjs": "^7.8.2",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "url": "https://github.com/mridang/railcross"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240129.0",
    "@jest/globals": "^30.0.3",
    "@mridang/eslint-defaults": "^1.5.0",
    "@opennextjs/cloudflare": "^1.14.6",
    "@tsconfig/node22": "^22.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cypress": "^14.4.0",
    "dotenv": "^16.5.0",
    "eslint": "^9.27.0",
    "jest": "^30.0.3",
    "knip": "^5.58.1",
    "nock": "^14.0.4",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.55.0"
  }
}
